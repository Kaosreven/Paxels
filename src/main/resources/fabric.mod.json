  "authors": [
    "Kaosreven"
  ],
  "contact": {
    "homepage": "https://github.com/Kaosreven",
    "sources": "https://github.com/Kaosreven/Paxels"
  },

  "license": "MIT",
  "icon": "assets/paxels/icon.png",

  "environment": "*",
