{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",

  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "Kaosreven"
  ],
  "contact": {
    "homepage": "https://github.com/Kaosreven",
    "sources": "${mod_source}"
  },

  "license": "${mod_license}",
  "icon": "assets/${mod_id}/icon.png",

  "environment": "*",
  "entrypoints": {
    "stationapi:event_bus": [
      "${maven_group}.${mod_id}.events.ItemListener",
      "${maven_group}.${mod_id}.events.RecipeListener"
    ],
    "stationapi:event_bus_client": [
      "${maven_group}.${mod_id}.events.TextureListener"
    ],
    "stationapi:event_bus_server": [
    ],
    "bhcreative:event_bus": [
      "${maven_group}.${mod_id}.events.CreativeListener"
    ]
  },
  "mixins": [
  ],

  "depends": {
    "minecraft": "1.0.0-beta.7.3",
    "stationapi": ">=${stapi_version}"
  }
}
